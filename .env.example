# Database connection string
DATABASE_URL=
# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Resend API key for sending email (https://resend.com)
RESEND_API_KEY=
# From address for outgoing email (must be on a Resend-verified domain;
# use onboarding@resend.dev for testing)
RESEND_FROM_ADDRESS=onboarding@resend.dev
RESEND_FROM_NAME=Music Express

# Vercel Blob token for media uploads (auto-added when you enable Blob in the
# Vercel dashboard -> Storage). Leave empty locally to use public/media.
BLOB_READ_WRITE_TOKEN=
